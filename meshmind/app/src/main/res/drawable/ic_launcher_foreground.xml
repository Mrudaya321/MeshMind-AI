<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Central Node -->
    <group android:translateX="54" android:translateY="54">
        <!-- Connecting lines -->
        <!-- Center to Top-Left -->
        <path
            android:strokeColor="@color/colorPrimary"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:pathData="M 0,0 L -25,-25" />
        <!-- Center to Top-Right -->
        <path
            android:strokeColor="@color/colorPrimary"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:pathData="M 0,0 L 25,-25" />
        <!-- Center to Bottom-Left -->
        <path
            android:strokeColor="@color/colorPrimary"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:pathData="M 0,0 L -25,25" />
        <!-- Center to Bottom-Right -->
        <path
            android:strokeColor="@color/colorPrimary"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:pathData="M 0,0 L 25,25" />
        <!-- Center to Left -->
        <path
            android:strokeColor="@color/colorPrimary"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:pathData="M 0,0 L -35,0" />
        <!-- Center to Right -->
        <path
            android:strokeColor="@color/colorPrimary"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:pathData="M 0,0 L 35,0" />

        <!-- Interconnecting outer ring/mesh -->
        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="2"
            android:strokeLineJoin="round"
            android:pathData="M -25,-25 L 25,-25 L 35,0 L 25,25 L -25,25 L -35,0 Z" />

        <!-- Draw nodes -->
        <!-- Center Node -->
        <path
            android:fillColor="@color/colorPrimary"
            android:pathData="M 0,-8 A 8,8 0 1,1 0,8 A 8,8 0 1,1 0,-8" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M 0,-4 A 4,4 0 1,1 0,4 A 4,4 0 1,1 0,-4" />

        <!-- Outer Nodes -->
        <path
            android:fillColor="@color/colorPrimary"
            android:pathData="M -25,-29 A 4,4 0 1,1 -25,-21 A 4,4 0 1,1 -25,-29" />
        <path
            android:fillColor="@color/colorPrimary"
            android:pathData="M 25,-29 A 4,4 0 1,1 25,-21 A 4,4 0 1,1 25,-29" />
        <path
            android:fillColor="@color/colorPrimary"
            android:pathData="M -25,21 A 4,4 0 1,1 -25,29 A 4,4 0 1,1 -25,21" />
        <path
            android:fillColor="@color/colorPrimary"
            android:pathData="M 25,21 A 4,4 0 1,1 25,29 A 4,4 0 1,1 25,21" />
        <path
            android:fillColor="@color/colorPrimary"
            android:pathData="M -39,-4 A 4,4 0 1,1 -31,-4 A 4,4 0 1,1 -39,-4" />
        <path
            android:fillColor="@color/colorPrimary"
            android:pathData="M 31,-4 A 4,4 0 1,1 39,-4 A 4,4 0 1,1 31,-4" />
    </group>
</vector>
